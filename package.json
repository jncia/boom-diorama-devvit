{
  "name": "boom-diorama",
  "version": "0.1.0",
  "private": true,
  "license": "BSD-3-Clause",
  "type": "module",
  "engines": {
    "node": ">=22.2.0"
  },
  "scripts": {
    "build:client": "vite build --config vite.client.config.js",
    "build:server": "esbuild src/server/index.js --bundle --platform=node --target=node22 --format=cjs --outfile=dist/server/index.cjs --external:node:* --legal-comments=none",
    "build": "npm run build:client && npm run build:server",
    "dev:client": "vite build --watch --config vite.client.config.js",
    "dev:server": "esbuild src/server/index.js --bundle --platform=node --target=node22 --format=cjs --outfile=dist/server/index.cjs --external:node:* --watch --legal-comments=none",
    "dev": "concurrently -n client,server,playtest -c blue,magenta,green \"npm:dev:client\" \"npm:dev:server\" \"devvit playtest\"",
    "playtest": "devvit playtest",
    "login": "devvit login",
    "upload": "devvit upload",
    "publish": "devvit publish"
  },
  "dependencies": {
    "@devvit/web": "0.12.20",
    "express": "^5.1.0",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "devvit": "0.12.20",
    "esbuild": "^0.24.0",
    "vite": "^5.4.0"
  }
}
